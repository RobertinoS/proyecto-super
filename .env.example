APP_ENV=staging
APP_VERSION=1.8.0
DATA_DIR=data
DATABASE_PATH=database/precios_san_juan.sqlite
EXPORT_DIR=data/export
REQUEST_TIMEOUT_SECONDS=120
REQUEST_DELAY_SECONDS=2
SCRAPER_USER_AGENT=Mozilla/5.0 ComparadorPreciosSanJuan/1.0
ENABLE_PLAYWRIGHT=false
SCRAPER_API_KEY=replace_me
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
RAW_BUCKET=raw-price-snapshots
PROCESSED_BUCKET=processed-price-datasets
PUBLISHED_BUCKET=published-price-datasets
MAX_PRODUCTS_PER_RUN=5
MAX_PAGES_PER_RUN=1
LOG_LEVEL=INFO
SOURCE_MODE=fixture
ENABLE_PUBLICATION=false
ENABLE_CLOUD_PUBLICATION=false
ENABLE_PRIVATE_PUBLICATION=false
SUPABASE_AUTH_ISSUER=https://example.supabase.co/auth/v1
SUPABASE_AUTH_AUDIENCE=authenticated
SUPABASE_AUTH_JWKS_URL=https://example.supabase.co/auth/v1/.well-known/jwks.json
AUTH_JWKS_CACHE_SECONDS=3600
DATASET_ACCESS_LOG_RETENTION_DAYS=365
PROJECT_SUPER_AUTOMATION_ENABLED=false
