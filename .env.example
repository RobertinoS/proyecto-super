APP_ENV=local
APP_VERSION=1.6.0
DATA_DIR=data
DATABASE_PATH=database/precios_san_juan.sqlite
EXPORT_DIR=data/export
REQUEST_TIMEOUT_SECONDS=30
REQUEST_DELAY_SECONDS=1.5
SCRAPER_USER_AGENT=Mozilla/5.0 ComparadorPreciosSanJuan/1.0
ENABLE_PLAYWRIGHT=false
SCRAPER_API_KEY=replace-with-a-long-random-value
SUPABASE_URL=https://example-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-only-in-render-secret-store
RAW_BUCKET=raw-price-snapshots
PROCESSED_BUCKET=processed-price-datasets
PUBLISHED_BUCKET=published-price-datasets
MAX_PRODUCTS_PER_RUN=100
MAX_PAGES_PER_RUN=2
LOG_LEVEL=INFO
SOURCE_MODE=fixture
ENABLE_PUBLICATION=false
